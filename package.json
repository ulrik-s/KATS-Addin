{
  "name": "kats-addin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.5.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "yarn build:icons && yarn build:canonical-hf && yarn build:manifest:dev && vite",
    "sideload": "yarn build:manifest:dev && node scripts/sideload-mac.mjs",
    "build": "yarn build:icons && yarn build:canonical-hf && vite build && yarn build:manifest",
    "build:icons": "node scripts/build-icons.mjs",
    "build:canonical-hf": "node scripts/build-canonical-hf.mjs",
    "build:manifest": "node scripts/build-manifest.mjs",
    "build:manifest:dev": "node scripts/build-manifest.mjs --dev",
    "preview": "vite preview",
    "check": "yarn typecheck && yarn lint && yarn format:check && yarn test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.1",
    "@types/office-js": "^1.0.454",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-basic-ssl": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
