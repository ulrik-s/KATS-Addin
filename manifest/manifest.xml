<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  KATS-Addin manifest — PLACEHOLDER.

  Populated in Fas 5 (UI) when taskpane.html and commands.html are hosted.
  Fields marked TODO must be replaced before sideloading / submitting to
  Microsoft 365 Admin Center (Integrated Apps).

  References:
    - https://learn.microsoft.com/office/dev/add-ins/develop/add-in-manifests
    - https://learn.microsoft.com/office/dev/add-ins/reference/manifest

  Hosting: GitHub Pages at https://<gh-user>.github.io/KATS-Addin/
  (HTTPS required by Office. GitHub Pages provides this automatically.)
-->
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
           xsi:type="TaskPaneApp">

  <!-- TODO: generate a stable GUID for production; keep one for dev, one for prod -->
  <Id>00000000-0000-0000-0000-000000000000</Id>
  <Version>0.0.0</Version>
  <ProviderName>MGA Advokater</ProviderName>
  <DefaultLocale>sv-SE</DefaultLocale>
  <DisplayName DefaultValue="KATS" />
  <Description DefaultValue="Transformerar KATS-taggade Word-dokument." />
  <!-- TODO: icon URLs (hosted on GitHub Pages) -->
  <IconUrl DefaultValue="https://example.invalid/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://example.invalid/icon-128.png" />
  <SupportUrl DefaultValue="https://github.com/TODO/KATS-Addin" />

  <AppDomains>
    <AppDomain>https://TODO.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document" />
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.4">
      <Set Name="WordApi" MinVersion="1.4" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://TODO.github.io/KATS-Addin/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- Ribbon button + commands added under VersionOverrides in Fas 5 -->
</OfficeApp>
